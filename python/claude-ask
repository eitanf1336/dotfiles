                                 self.on_new)
        self.b_later = self._mkbtn('alarm-symbolic', 'Move to Later',
                                   self.on_later)
        self.b_term = self._mkbtn('utilities-terminal-symbolic',
                                  'Open in terminal', self.on_terminal)
        btns.pack_start(self.b_followup, False, False, 0)
        btns.pack_start(self.b_new, False, False, 0)
        btns.pack_start(self.b_later, False, False, 0)
        btns.pack_end(self.b_term, False, False, 0)
        self.answer_view.pack_start(btns, False, False, 0)
        self.root.pack_start(self.answer_view, True, True, 0)

        # register on the board of live bars, then keep tiling in sync
        reg_register(time.time())
        atexit.register(reg_unregister)
        self._idx, self._n = reg_position()
        self._recompute_columns()
        GLib.timeout_add(600, self._poll)

        self.show_all()
        self.loading_view.hide()
        self.answer_view.hide()
        self.set_state('input')
        GLib.idle_add(self._post_show)

    def _mkbtn(self, icon, tip, cb, primary=False):
        b = Gtk.Button()
        img = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.SMALL_TOOLBAR)
        b.set_image(img)
        b.set_always_show_image(True)
        b.set_tooltip_text(tip)
        b.get_style_context().add_class('btn')
        if primary:
            b.get_style_context().add_class('primary')
        b.connect('clicked', cb)
        return b

    def new_session(self):
        # Both resolved on first send, once the bg agent is created.
        self.session_id = None      # the agent's real session UUID
        self.short_id = None        # the agent's 8-char id (attach/stop/logs)
        self._cwd = HOME
        self.has_session = False

    def _update_badge(self):
        p = PRESETS[self.preset_i]
        self.badge.set_markup('<span foreground="%s">◆</span> %s · think %s'
                              % (self.accent, p['label'], p['effort']))

    def _on_sigusr1(self):
        # hotkey pressed again on the focused bar -> cycle the model preset
        self.preset_i = (self.preset_i + 1) % len(PRESETS)
        self._update_badge()
        return True

    def _post_show(self):
        """Runs once after the window is realized. Re-render the badge now that
        CSS is resolved (markup set pre-realize caches a too-large layout — this
        is what made the size 'snap good' on the first toggle), and measure the
        widest badge + ✕ so the bar's minimum width never lets them overlap."""
        self._update_badge()
        try:
            widest = 0
            for p in PRESETS:
                self.badge.set_markup('<span>◆</span> %s · think %s'
                                      % (p['label'], p['effort']))
                widest = max(widest, self.badge.get_preferred_width()[1])
            xw = self.close_btn.get_preferred_width()[1]
            self._badge_min = 18 + widest + 16 + xw + 14
        except Exception:
            pass
        self._update_badge()   # restore current preset's coloured text
        self._refit()
        return False

