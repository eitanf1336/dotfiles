        self.overlay.add_overlay(self.close_btn)

        # ---- input view: chevron + single-line Entry (grows wider as you type)
        self.input_view = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        self.input_view.get_style_context().add_class('inputrow')
