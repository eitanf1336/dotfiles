        if vis:
            self.set_visual(vis)
        self.connect('key-press-event', self.on_window_key)
        self.connect('destroy', self.on_destroy)
        self.connect('size-allocate', lambda *a: self._reposition())
        # Pressing the hotkey again while this bar is focused signals it here.
        GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGUSR1,
                             self._on_sigusr1)

        self._apply_css()

        # Overlay so the model badge can straddle the top border and the ✕ can
