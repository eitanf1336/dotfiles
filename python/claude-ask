    # --- geometry / tiling ---
    def _monitor_geo(self):
        d = Gdk.Display.get_default()
        m = d.get_primary_monitor() or d.get_monitor(0)
        return m.get_geometry()

    def _recompute_columns(self):
        geo = self._monitor_geo()
        avail = geo.width - 2 * SIDE_MARGIN
        n = max(1, self._n)
        self.col_width = (avail if n <= 1
                          else max(360.0, (avail - (n - 1) * GAP) / n))
        # cap how wide the wrapped response gets to this bar's column
        if hasattr(self, 'resp_label'):
            chars = max(26, min(72, int((min(self.col_width, BASE_WIDTH) - 60)
                                        / 11.4)))
            self.resp_label.set_max_width_chars(chars)

    def _apply_width(self):
        """Input bar: minimal, then grows with the typed text (clamped to this
        bar's column). Loading: a small fixed bar. Answer: size to the content."""
        st = getattr(self, 'state', 'input')
        if st == 'input':
            lay = self.entry.get_layout()
            tw = lay.get_pixel_size()[0] if lay else 0
            floor = max(INPUT_MIN, self._badge_min)
            target = max(floor, min(int(self.col_width), tw + OVERHEAD))
            self.set_size_request(target, -1)
        elif st == 'loading':
            self.set_size_request(LOADING_W, -1)
        else:  # answer — let the window hug the response + buttons
            self.set_size_request(1, -1)

    def _reposition(self):
        try:
            geo = self._monitor_geo()
            n = max(1, self._n)
            col = self.col_width
            w, h = self.get_size()
            group_w = n * col + (n - 1) * GAP
            left = geo.x + (geo.width - group_w) / 2.0
            colx = left + self._idx * (col + GAP)
            x = int(colx + (col - w) / 2.0)
            y = geo.y + geo.height - h - BOTTOM_MARGIN
            self.move(x, y)
        except Exception:
            pass

    def _refit(self):
        self._apply_width()
        self._reposition()

    def _poll(self):
        idx, n = reg_position()
        if (idx, n) != (self._idx, self._n):
            self._idx, self._n = idx, n
            self._recompute_columns()
            self._refit()
        return True

    # --- state machine ---
    def set_state(self, state):
        self.state = state
        self.input_view.set_visible(state == 'input')
        self.loading_view.set_visible(state == 'loading')
        self.answer_view.set_visible(state == 'answer')
        if state == 'loading':
            self._start_pulse()
        else:
            self._stop_pulse()
        if state == 'input':
            self.entry.grab_focus()
        self._apply_width()
        GLib.idle_add(self._anchor)

    def _anchor(self):
        self._reposition()
        self.present()
        return False

    def _start_pulse(self):
        self.load_label.set_text('❯ thinking')
        self._dots = 0
        if not self._pulse_id:
            self._pulse_id = GLib.timeout_add(90, self._tick)

    def _tick(self):
        self.pulse.pulse()
        self._dots = (self._dots + 1) % 24
        self.load_label.set_text('❯ thinking' + '.' * (self._dots // 6))
        return True

    def _stop_pulse(self):
        if self._pulse_id:
            GLib.source_remove(self._pulse_id)
            self._pulse_id = 0

    # --- input handling ---
    def on_window_key(self, w, ev):
        if ev.keyval == Gdk.KEY_Escape:
            self.destroy()
            return True
        ctrl = ev.state & Gdk.ModifierType.CONTROL_MASK
        shift = ev.state & Gdk.ModifierType.SHIFT_MASK
        if ctrl and shift and ev.keyval in (Gdk.KEY_q, Gdk.KEY_Q):
            self.destroy()
            return True
        return False

    def send(self):
        if self.busy:
            return
        prompt = self.entry.get_text().strip()
        if not prompt:
            return
        self.busy = True
        self.full_response = ''
        self.resp_label.set_text('')
        self.set_state('loading')
        preset = PRESETS[self.preset_i]
        threading.Thread(target=self._run, args=(prompt, preset),
                         daemon=True).start()

    def _run(self, prompt, preset):
        # The chat IS a real background agent (exactly like claude-c's 'n').
        # Create an idle bg agent on first send, then attach via a hidden pty,
        # inject the prompt, tail the session jsonl for the answer, and Ctrl+Z
        # to detach — the agent stays alive so Ctrl+Z in claude-c keeps it
        # thinking instead of killing it.
        try:
            if not self.short_id:
                if not self._create_agent(preset):
                    return
            self._inject_and_stream(prompt)
        except Exception as e:
            GLib.idle_add(self._error, str(e))

    def _create_agent(self, preset):
        cmd = ['claude', '--bg',
               '--model', preset['model'], '--effort', preset['effort']]
        out = subprocess.run(cmd, capture_output=True, text=True,
                             timeout=60, cwd=HOME).stdout
        m = re.search(r'([0-9a-f]{8})', strip_ansi(out))
        if not m:
            GLib.idle_add(self._error, 'could not create agent')
            return False
        short = m.group(1)
        rec = None
        for _ in range(40):
            rec = agent_record(short)
            if rec and rec.get('sessionId'):
                break
            time.sleep(0.2)
        if not rec or not rec.get('sessionId'):
            GLib.idle_add(self._error, 'agent did not register')
            return False
        self.short_id = short
        self.session_id = rec.get('sessionId')
        self._cwd = rec.get('cwd') or HOME
        GLib.idle_add(self._mark_filed)
        return True

    def _inject_and_stream(self, prompt):
        short, sid = self.short_id, self.session_id
        pid, fd = pty.fork()
        if pid == 0:
            try:
                os.execvp('claude', ['claude', 'attach', short])
            except Exception:
                os._exit(1)
        # parent: let attach settle, snapshot the jsonl, inject, then tail.
        self._drain(fd, 1.6)
        jf = jsonl_for(sid)
        base = count_lines(jf) if jf else 0
        try:
            os.write(fd, prompt.encode() + b'\r')
        except Exception:
            pass
        last = ''
        stable = 0
        for _ in range(900):          # ~180s ceiling
            self._drain(fd, 0.2)
            if jf is None:
                jf = jsonl_for(sid)
                base = 0
            cur = turn_text(jf, base) if jf else ''
            if cur and cur != last:
                last = cur
                GLib.idle_add(self._stream_set, cur)
                stable = 0
            elif cur:
                stable += 1
                if stable >= 8:       # ~1.6s no change -> turn done
                    break
            if not agent_alive(short):
                break
        # detach, leaving the agent alive
        try:
            os.write(fd, b'\x1a')
            self._drain(fd, 0.4)
        except Exception:
            pass
        try:
            os.close(fd)
        except Exception:
            pass
        try:
            os.kill(pid, signal.SIGKILL)
            os.waitpid(pid, 0)
        except Exception:
            pass
        GLib.idle_add(self._finish, bool(last))

    def _drain(self, fd, secs):
        end = time.time() + secs
        while time.time() < end:
            r, _, _ = select.select([fd], [], [], max(0, end - time.time()))
            if not r:
                continue
            try:
                if not os.read(fd, 65536):
                    break
            except OSError:
                break

    def _mark_filed(self):
        if not self.filed and self.session_id:
            cat_set(self.session_id, 'In Progress')
            self.filed = True
        return False

    def _stream_set(self, text):
        if self.state != 'answer':
            self.set_state('answer')
        self.full_response = text
        self.resp_label.set_text(text)
        adj = self.resp_scroll.get_vadjustment()
        adj.set_value(adj.get_upper())
        return False

    def _finish(self, ok):
        if self.state != 'answer':
            self.set_state('answer')
        if self.full_response:
            self.resp_label.set_markup(
                md_to_pango(self.full_response, self.accent))
        else:
            self.resp_label.set_text('(no response)')
        self.busy = False
        self.has_session = True
        GLib.idle_add(self._anchor)
        return False

    def _error(self, msg):
        self.set_state('answer')
        self.resp_label.set_text('⚠ ' + msg)
        self.busy = False
        return False

    # --- answer-view buttons ---
    def on_terminal(self, btn):
        self.final_category = 'In Progress'
        if self.short_id:
            open_terminal('claude attach %s' % self.short_id, 'claude')
        self.destroy()

    def on_later(self, btn):
        self.final_category = 'Later'
        self.destroy()

    def on_new(self, btn):
        self.new_session()
        self.filed = False
        self.entry.set_text('')
        self.set_state('input')

    def on_followup(self, btn):
        self.entry.set_text('')
        self.set_state('input')

    def on_destroy(self, *a):
        # The chat is a live bg agent; never stop it and never mark it Done.
        if self.filed and self.session_id:
            cat_set(self.session_id, self.final_category or 'In Progress')
        reg_unregister()
        Gtk.main_quit()


def selftest():
    # Exercise the real bg-agent path end to end: create idle agent, attach
    # via pty, inject a prompt, tail the jsonl for the answer, Ctrl+Z detach,
    # then confirm the agent is STILL alive (the whole point of the rewrite).
    preset = PRESETS[0]
    out = subprocess.run(['claude', '--bg', '--model', preset['model'],
                          '--effort', preset['effort']],
                         capture_output=True, text=True, timeout=60,
                         cwd=HOME).stdout
    m = re.search(r'([0-9a-f]{8})', strip_ansi(out))
    if not m:
        print('FAIL: no agent id in', repr(out)); sys.exit(1)
    short = m.group(1)
    rec = None
    for _ in range(40):
        rec = agent_record(short)
        if rec and rec.get('sessionId'):
            break
        time.sleep(0.2)
    if not rec or not rec.get('sessionId'):
        print('FAIL: agent did not register'); sys.exit(1)
    sid = rec['sessionId']
    print('agent', short, 'session', sid)
    pid, fd = pty.fork()
    if pid == 0:
        try:
            os.execvp('claude', ['claude', 'attach', short])
        except Exception:
            os._exit(1)

    def drain(secs):
        end = time.time() + secs
        while time.time() < end:
            r, _, _ = select.select([fd], [], [], max(0, end - time.time()))
            if not r:
                continue
            try:
                if not os.read(fd, 65536):
                    break
            except OSError:
                break

    drain(1.6)
    jf = jsonl_for(sid)
    base = count_lines(jf) if jf else 0
    os.write(fd, b'reply with exactly: pong\r')
    last, stable = '', 0
    for _ in range(300):
        drain(0.2)
        if jf is None:
            jf = jsonl_for(sid); base = 0
        cur = turn_text(jf, base) if jf else ''
        if cur and cur != last:
            last = cur; stable = 0
        elif cur:
            stable += 1
            if stable >= 8:
                break
        if not agent_alive(short):
            break
    os.write(fd, b'\x1a')
    drain(0.4)
    os.close(fd)
    try:
        os.kill(pid, signal.SIGKILL); os.waitpid(pid, 0)
    except Exception:
        pass
    alive = agent_alive(short)
    print('answer:', repr(last))
    print('agent alive after detach:', alive)
    subprocess.run(['claude', 'stop', short],
                   capture_output=True, text=True, timeout=30)
    if jf and os.path.exists(jf):
        try:
            os.remove(jf)
        except Exception:
            pass
    sys.exit(0 if (last.strip() and alive) else 1)


if __name__ == '__main__':
    if '--selftest' in sys.argv:
        selftest()
