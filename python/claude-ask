#!/usr/bin/env python3
"""claude-ask — a futuristic quick-prompt bar that slides up from the bottom.

Each Ctrl+Shift+A opens another bar; live bars re-tile side-by-side at the
bottom of the primary screen (a single bar grows wide as you type, several
share the width). Ctrl+Shift+Q / Esc close the focused bar.

States: INPUT -> LOADING -> ANSWER. Answer view:
  follow up           -> back to input, same conversation continues
  ask something new    -> fresh session, back to input
  mv to Later          -> file the chat under Later, close
  open terminal        -> drop the exact conversation into a terminal
The chat is filed on the claude-c board (categories.json) as In Progress on the
first send; plain-close lands it in Done. Accent tracks the wallpaper theme.
"""
import os
# Force X11/XWayland so we can position the window (native Wayland forbids it).
os.environ.setdefault('GDK_BACKEND', 'x11')

import sys, json, uuid, threading, subprocess, html, re, shutil, shlex, fcntl
import time, errno, atexit, signal, pty, select, glob
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib, Pango

BASE_WIDTH = 620        # only an upper hint now; input starts minimal
INPUT_MIN = 250         # minimal input-bar width (fits "❯ ask claude…" at 1.5× font)
OVERHEAD = 130          # chevron + paddings + right reserve for the ✕, added to text width
LOADING_W = 340
ANSWER_MAX_H = 440
BOTTOM_MARGIN = 70
SIDE_MARGIN = 40
GAP = 16
PID = os.getpid()

# Model presets cycled by pressing the hotkey again while a bar is focused.
# index 0 = smart default, 1 = fastest-that-isn't-dumb.
PRESETS = [
    {'label': 'opus',   'model': 'opus',   'effort': 'high'},
    {'label': 'sonnet', 'model': 'sonnet', 'effort': 'medium'},
]

# --- theme: borrow the current wallpaper-rotation accent ---------------------
ORDER = ['green', 'blue', 'purple', 'red', 'gold', 'brown', 'wood']
ACCENTS = {'green': '#4ade80', 'blue': '#60a5fa', 'purple': '#c084fc',
           'red': '#f87171', 'gold': '#fbbf24', 'brown': '#d2a679',
           'wood': '#deb887'}


def current_accent():
    try:
        p = os.path.expanduser('~/.local/state/desktop-rotation/index')
        idx = int(open(p).read().strip())
        return ACCENTS[ORDER[idx % len(ORDER)]]
    except Exception:
        return '#c084fc'


def hex_rgba(h, a):
    h = h.lstrip('#')
    r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
    return 'rgba(%d,%d,%d,%s)' % (r, g, b, a)


# --- claude-c board integration: file this chat into categories.json ---------
STORE = os.path.expanduser('~/.claude/chats/categories.json')


def cat_set(session_id, value):
    """Locked set of one category key (value=None deletes). Mirrors chats.py
    `_json_set` (atomic write, indent=2), keyed by full session UUID."""
    try:
        os.makedirs(os.path.dirname(STORE), exist_ok=True)
        lock = STORE + '.lock'
        with open(lock, 'w') as lf:
            fcntl.flock(lf, fcntl.LOCK_EX)
            try:
                try:
                    d = json.load(open(STORE))
                except Exception:
                    d = {}
                if value is None:
                    d.pop(session_id, None)
                else:
                    d[session_id] = value
                tmp = STORE + '.tmp'
                with open(tmp, 'w') as f:
                    json.dump(d, f, indent=2)
                os.replace(tmp, STORE)
            finally:
                fcntl.flock(lf, fcntl.LOCK_UN)
    except Exception:
        pass


# --- background-agent helpers ------------------------------------------------
# The chat is a REAL background agent (created like claude-c's 'n': bare
# `claude --bg`, which stays idle+live awaiting input). We drive it through a
# hidden `claude attach` pty: type the prompt, read the answer from the session
# jsonl, then send Ctrl+Z to detach — the agent stays alive. Because the chat is
# a genuine live agent, opening it later in claude-c uses the attach path, so
# Ctrl+Z keeps it thinking instead of killing it (the whole reason for this).
HOME = os.path.expanduser('~')
_ANSI = re.compile(r'\x1b\[[0-9;?]*[A-Za-z]')


def strip_ansi(s):
    return _ANSI.sub('', s)


def agents_json():
    try:
        out = subprocess.run(['claude', 'agents', '--json'],
                             capture_output=True, text=True, timeout=15).stdout
        d = json.loads(out)
        return d if isinstance(d, list) else []
    except Exception:
        return []


def agent_record(short):
    return next((a for a in agents_json() if a.get('id') == short), None)


def agent_alive(short):
    return agent_record(short) is not None


def jsonl_for(sid):
    if not sid:
        return None
    hits = glob.glob(os.path.join(HOME, '.claude', 'projects', '*',
                                  '%s.jsonl' % sid))
    return hits[0] if hits else None


def count_lines(p):
    try:
        with open(p) as fh:
            return sum(1 for _ in fh)
    except Exception:
        return 0


def turn_text(jf, base_lines):
    """Assistant text written AFTER base_lines (i.e. this turn's answer)."""
    out = []
    try:
        with open(jf) as fh:
            for i, line in enumerate(fh):
                if i < base_lines:
                    continue
                try:
                    o = json.loads(line)
                except Exception:
                    continue
                if o.get('type') == 'assistant':
                    for b in o.get('message', {}).get('content', []):
                        if isinstance(b, dict) and b.get('type') == 'text':
                            out.append(b.get('text', ''))
    except Exception:
        return ''
    return '\n'.join(out).strip()


# --- instance registry: lets concurrent bars tile without overlapping --------
REG_DIR = os.path.expanduser('~/.cache/claude-ask')
REG = os.path.join(REG_DIR, 'instances.json')


def _alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except OSError as e:
        return e.errno == errno.EPERM


def _reg_locked(mutate):
    """Locked read (with dead-PID prune) -> mutate -> write. Returns the dict."""
    try:
        os.makedirs(REG_DIR, exist_ok=True)
        lock = REG + '.lock'
        with open(lock, 'w') as lf:
            fcntl.flock(lf, fcntl.LOCK_EX)
            try:
                try:
                    d = json.load(open(REG))
                except Exception:
                    d = {}
                d = {k: v for k, v in d.items() if _alive(int(k))}
                if mutate:
                    mutate(d)
                tmp = REG + '.tmp'
                with open(tmp, 'w') as f:
                    json.dump(d, f)
                os.replace(tmp, REG)
                return d
            finally:
                fcntl.flock(lf, fcntl.LOCK_UN)
    except Exception:
        return {str(PID): 0}


def reg_register(order):
    _reg_locked(lambda d: d.__setitem__(str(PID), order))


def reg_unregister():
    _reg_locked(lambda d: d.pop(str(PID), None))


def reg_position():
    """Return (index, count) of this PID among live bars, ordered by open time."""
    d = _reg_locked(None)
    if str(PID) not in d:
        d[str(PID)] = time.time()
    pids = sorted(d.keys(), key=lambda k: (d[k], int(k)))
    n = len(pids)
    idx = pids.index(str(PID)) if str(PID) in pids else n - 1
    return idx, max(1, n)


def active_window_pid():
    """PID of the currently focused X window, via xprop (no xdotool needed)."""
    try:
        r = subprocess.run(['xprop', '-root', '_NET_ACTIVE_WINDOW'],
                           capture_output=True, text=True, timeout=2).stdout
        m = re.search(r'0x[0-9a-fA-F]+', r)
        if not m:
            return None
        r2 = subprocess.run(['xprop', '-id', m.group(0), '_NET_WM_PID'],
                            capture_output=True, text=True, timeout=2).stdout
        m2 = re.search(r'=\s*(\d+)', r2)
        return int(m2.group(1)) if m2 else None
    except Exception:
        return None


# --- tiny markdown -> Pango markup (for the finished response) ----------------
def md_to_pango(text, accent):
    out = []
    parts = text.split('```')
    for n, chunk in enumerate(parts):
        if n % 2 == 1:
            code = chunk
            first = code.split('\n', 1)[0]
            if '\n' in code and first.strip().isalpha():
                code = code.split('\n', 1)[1]
            out.append('<span background="#16161f"><tt>%s</tt></span>'
                       % html.escape(code.strip('\n')))
            continue
        lines = []
        for line in chunk.split('\n'):
            m = re.match(r'^(#{1,6})\s+(.*)', line)
            if m:
                lines.append('<big><b>%s</b></big>' % html.escape(m.group(2)))
                continue
            esc = html.escape(line)
            esc = re.sub(r'`([^`]+)`',
                         lambda x: '<span background="#16161f"><tt>%s</tt></span>'
                         % x.group(1), esc)
            esc = re.sub(r'\*\*([^*]+)\*\*', r'<b>\1</b>', esc)
            esc = re.sub(r'(?<!\*)\*([^*]+)\*(?!\*)', r'<i>\1</i>', esc)
            esc = re.sub(r'^(\s*)[-*]\s+',
                         lambda x: x.group(1) + '<span foreground="%s">▸</span> '
                         % accent, esc)
            lines.append(esc)
        out.append('\n'.join(lines))
    return ''.join(out)


def find_terminal():
    for t in ('terminator', 'gnome-terminal', 'x-terminal-emulator', 'xterm'):
        if shutil.which(t):
            return t
    return None


def open_terminal(cmd, title='claude'):
    term = find_terminal()
    if not term:
        return
    if term == 'terminator':
        subprocess.Popen([term, '-T', title, '-e',
                          "bash -lc '%s; exec bash'" % cmd])
    elif term == 'gnome-terminal':
        subprocess.Popen([term, '--title', title, '--', 'bash', '-lc',
                          '%s; exec bash' % cmd])
    else:
        subprocess.Popen([term, '-e',
                          'bash -lc %s' % shlex.quote('%s; exec bash' % cmd)])


