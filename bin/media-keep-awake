#!/usr/bin/env bash
# media-keep-awake : stop the screen blanking while music or video is actually playing.
# Written 2026-07-14 for the "screen blanks even though Spotify is playing" issue.
#
# Why this exists: Linux Spotify (and some other players) never register a GNOME
# idle inhibitor, so gsd-power dims and blanks the screen on its normal timeout
# even mid-track. This watches every MPRIS player on the session bus and holds
# an idle inhibitor for exactly as long as one of them reports "Playing".
#
# Paused/stopped players are ignored, so the screen still blanks normally when
# nothing is actually playing.
#
# Usage:  media-keep-awake             # run the watch loop (the systemd service does this)
#         media-keep-awake --status    # show players, their state, and current inhibitors
#         media-keep-awake --once      # print whether something is playing, then exit
set -uo pipefail

INTERVAL="${MEDIA_KEEP_AWAKE_INTERVAL:-15}"
APP_ID="media-keep-awake"
REASON="Media is playing"

# Every MPRIS player currently on the session bus.
players() {
    busctl --user list --no-pager --no-legend 2>/dev/null \
        | awk '{print $1}' \
        | grep '^org\.mpris\.MediaPlayer2\.' \
        | sort -u
}

status_of() {
    busctl --user get-property "$1" /org/mpris/MediaPlayer2 \
        org.mpris.MediaPlayer2.Player PlaybackStatus 2>/dev/null \
        | sed 's/^s "//; s/"$//'
}

# 0 if any player is actively Playing.
any_playing() {
    local p
    while read -r p; do
        [ -z "$p" ] && continue
        [ "$(status_of "$p")" = "Playing" ] && return 0
    done < <(players)
    return 1
}

case "${1:-}" in
--status)
    echo "MPRIS players:"
    found=0
    while read -r p; do
        [ -z "$p" ] && continue
        found=1
        printf '  %-45s %s\n' "$p" "$(status_of "$p")"
    done < <(players)
    [ "$found" = 0 ] && echo "  (none)"
    echo
    echo "Session inhibitors:"
    gnome-session-inhibit --list 2>&1 | sed 's/^/  /'
    exit 0
    ;;
--once)
    if any_playing; then echo "playing"; else echo "idle"; fi
    exit 0
    ;;
-h | --help)
    sed -n '2,12p' "$0" | sed 's/^# \?//'
    exit 0
    ;;
esac

INHIBIT_PID=""

drop_inhibit() {
    if [ -n "$INHIBIT_PID" ] && kill -0 "$INHIBIT_PID" 2>/dev/null; then
        kill "$INHIBIT_PID" 2>/dev/null
        wait "$INHIBIT_PID" 2>/dev/null
    fi
    INHIBIT_PID=""
}

trap 'drop_inhibit; exit 0' TERM INT

echo "media-keep-awake: watching MPRIS every ${INTERVAL}s"

while true; do
    if any_playing; then
        if [ -z "$INHIBIT_PID" ] || ! kill -0 "$INHIBIT_PID" 2>/dev/null; then
            gnome-session-inhibit --app-id="$APP_ID" --reason="$REASON" \
                --inhibit=idle --inhibit-only &
            INHIBIT_PID=$!
            echo "media-keep-awake: playback started, holding idle inhibitor (pid $INHIBIT_PID)"
        fi
    elif [ -n "$INHIBIT_PID" ]; then
        drop_inhibit
        echo "media-keep-awake: playback stopped, released idle inhibitor"
    fi
    sleep "$INTERVAL"
done
