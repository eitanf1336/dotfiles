#!/usr/bin/env bash
# Outlook on the Web as a standalone desktop app (Chrome --app mode).
# Uses your normal Chrome profile so it opens the account you're already
# signed into (Technion: eitanfrenkel@campus.technion.ac.il), matching the
# "Outlook (Technion)" launcher in the Super/Activities search.
URL="https://outlook.office.com/mail/"
setsid -f /usr/bin/google-chrome \
  --app="$URL" \
  --class=OutlookWeb \
  --name=OutlookWeb \
  >/dev/null 2>&1
