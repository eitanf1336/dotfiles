#!/usr/bin/env bash
# claude-beep: play a short chime when a Claude session finishes writing.
#
# Wired up as a Stop hook in ~/.claude/settings.json, so it fires for every
# Claude session that finishes a reply: interactive chats (including the ones
# claude-c runs), background agents, and headless runs alike.
#
# Silent while "Sleeping" is on. That toggle lives in the GNOME quick settings
# panel (the claude-beep@eitan.local extension) and is just a marker file, so it
# can be flipped from here too:
#
#   claude-beep                  play the chime (unless sleeping)
#   claude-beep --test           play it even while sleeping, to audition it
#   claude-beep --sleep on|off|toggle|status
#
# The sound is whatever path or libcanberra event id sits in
# ~/.config/claude-beep/sound; see DEFAULT_SOUND below.
set -uo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude-beep"
SLEEP_FILE="$STATE_DIR/sleeping"
LAST_FILE="$STATE_DIR/last-beep"
SOUND_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/claude-beep/sound"
# The cute two-note chirp, generated by linux-setup/sounds/make-chime.py.
DEFAULT_SOUND="${XDG_DATA_HOME:-$HOME/.local/share}/claude-beep/claude-done.wav"
FALLBACK_SOUND="/usr/share/sounds/freedesktop/stereo/complete.oga"

# Several agents finishing together should be one chime, not a pile-up.
DEBOUNCE_SECS=2

die() { printf '%s\n' "$*" >&2; exit 1; }

sleeping() { [ -e "$SLEEP_FILE" ]; }

set_sleeping() {
    case "$1" in
        on)     mkdir -p "$STATE_DIR"; : > "$SLEEP_FILE" ;;
        off)    rm -f "$SLEEP_FILE" ;;
        toggle) if sleeping; then set_sleeping off; else set_sleeping on; fi ;;
        *)      die "claude-beep: unknown sleep state '$1' (on|off|toggle|status)" ;;
    esac
}

sound_file() {
    if [ -n "${CLAUDE_BEEP_SOUND:-}" ]; then
        printf '%s' "$CLAUDE_BEEP_SOUND"
    elif [ -s "$SOUND_CONF" ]; then
        head -n1 "$SOUND_CONF"
    elif [ -r "$DEFAULT_SOUND" ]; then
        printf '%s' "$DEFAULT_SOUND"
    else
        printf '%s' "$FALLBACK_SOUND"
    fi
}

play() {
    local sound; sound="$(sound_file)"
    # A bare name (no slash) is a sound-theme event id, which only canberra
    # knows how to resolve; a path can go to either player.
    if [ "${sound#*/}" = "$sound" ]; then
        exec canberra-gtk-play -i "$sound" >/dev/null 2>&1
    fi
    [ -r "$sound" ] || die "claude-beep: no readable sound at '$sound'"
    if command -v pw-play >/dev/null 2>&1; then
        exec pw-play "$sound" >/dev/null 2>&1
    fi
    exec canberra-gtk-play -f "$sound" >/dev/null 2>&1
}

# Skip a chime that lands within DEBOUNCE_SECS of the previous one.
debounced() {
    local now last
    now=$(date +%s)
    last=$(cat "$LAST_FILE" 2>/dev/null) || last=0
    case "$last" in ''|*[!0-9]*) last=0 ;; esac
    if [ $((now - last)) -lt "$DEBOUNCE_SECS" ]; then
        return 0
    fi
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$now" > "$LAST_FILE"
    return 1
}

case "${1:-}" in
    --sleep|sleep)
        case "${2:-status}" in
            status) sleeping && echo "sleeping (Claude beeps are muted)" || echo "awake (Claude beeps are on)" ;;
            *)      set_sleeping "$2"
                    sleeping && echo "sleeping (Claude beeps are muted)" || echo "awake (Claude beeps are on)" ;;
        esac
        ;;
    --test|test)
        play
        ;;
    ''|--play|play)
        # Stop hooks get the session JSON on stdin; nothing here needs it, but
        # draining it keeps Claude from seeing a broken pipe.
        [ -t 0 ] || cat >/dev/null 2>&1
        sleeping && exit 0
        debounced && exit 0
        play
        ;;
    -h|--help)
        sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
        ;;
    *)
        die "claude-beep: unknown argument '$1' (try --help)"
        ;;
esac
